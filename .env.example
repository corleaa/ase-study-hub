# ─────────────────────────────────────────────────────────────────
# .env.example — Copy this file to backend/.env and fill in values.
#
#   cp .env.example backend/.env
#
# This file is safe to commit. backend/.env is NOT — it contains real secrets.
# ─────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────
# Port the Express server listens on.
PORT=3001

# Set to 'production' when deploying. Affects: secure cookies, HSTS,
# error message verbosity, trust proxy behaviour.
NODE_ENV=development

# ── Security ──────────────────────────────────────────────────────
# Secret used to sign JWT access tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Must be at least 32 characters. Keep this private — anyone with this
# value can forge authentication tokens for any user.
JWT_SECRET=replace_with_64_char_random_hex_string

# ── Anthropic API ─────────────────────────────────────────────────
# API key for Claude (AI features: quiz, flashcards, mentor, summarize).
# Get yours at: https://console.anthropic.com/settings/keys
# This key is ONLY used server-side. It is never sent to the browser.
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In development: http://localhost:3001
# In production: your actual domain, e.g. https://studyhub.example.com
ALLOWED_ORIGINS=http://localhost:3001

# ── File upload ───────────────────────────────────────────────────
# Maximum upload file size in bytes. Default: 5MB (5242880).
MAX_FILE_SIZE=5242880
